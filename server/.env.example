# ── Railway / Production ─────────────────────────────────────────────
# Railway sets PORT and DATABASE_URL automatically when you add PostgreSQL.

PORT=8000
NODE_ENV=production

# Comma-separated — include your Vercel URL after deploy
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Required — use a long random string (32+ chars)
JWT_SECRET=change-me-to-a-long-random-production-secret

# Railway PostgreSQL (auto-injected when you link the database service)
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Your public Vercel frontend URL (used in email links)
APP_URL=https://your-app.vercel.app

# Email (Gmail app password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_NAME=VendorBridge

JWT_EXPIRES_IN=7d
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
